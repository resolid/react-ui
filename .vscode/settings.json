{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "oxc.typeAware": true,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.classFunctions": ["tv", "tx"],
  "tailwindCSS.experimental.configFile": "./website/src/root.css",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "npm.enableRunFromFolder": true,
  "npm.exclude": ["**/build/**", "**/.vercel/**"],
  "files.watcherExclude": {
    "**/.vercel/**": true,
    "**/build/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/.vercel/**": true,
    "**/build/**": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    ".env": "*.env, .env.*, .envrc, env.d.ts",
    ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .lfsconfig, .mailmap, .git-blame*",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock, .editorconfig, lefthook.*, .pnpm*, .commitlint*, .npm*, .eslint*, eslint*, .prettier*",
    "vite.config.*": "vitest.config.*, tsdown.config.*, react-router.config.*",
    "README*": "LICENSE*, README.*, CODE_OF_CONDUCT*, CONTRIBUTING*, CHANGELOG*"
  },
  "prettier.enable": false,
  "eslint.enable": false,
  "reactCompilerMarker.excludedDirectories": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "out",
    "coverage",
    ".next",
    ".turbo",
    ".vercel",
    ".resolid"
  ],
  "js/ts.implicitProjectConfig.target": "ES2022",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true
}
