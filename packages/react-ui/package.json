{
  "name": "@resolid/react-ui",
  "version": "0.3.6",
  "private": false,
  "description": "A React design system built with Tailwind CSS, offering ready-to-use components for consistent UI.",
  "keywords": [
    "react",
    "react-hook",
    "resolid",
    "tailwindcss"
  ],
  "homepage": "https://ui.resolid.tech",
  "license": "MIT",
  "author": "Huijie Wei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/react-ui.git",
    "directory": "packages/react-ui"
  },
  "files": [
    "dist",
    "tailwindcss"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./locales/*": {
      "types": "./dist/locales/*.d.ts",
      "import": "./dist/locales/*.js"
    },
    "./tailwindcss": "./tailwindcss/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.20",
    "@resolid/utils": "^1.7.0",
    "@tanstack/react-virtual": "^3.14.6",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/pretty-format": "^4.1.10",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.7",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  }
}
